# LLM Configuration (DeepSeek, GitHub Models, OpenAI, etc.)
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# Search Configuration
# Providers: tavily, serper, custom
SEARCH_API_PROVIDER=tavily
SEARCH_API_KEY=your_search_api_key

# Specific Provider Keys (Optional if SEARCH_API_KEY is set)
TAVILY_API_KEY=tvly-xxxxxxxxxxxx
SERPER_API_KEY=xxxxxxxxxxxx

# Workflow Settings
MAX_RESEARCH_ITERATIONS=5
MAX_SOURCES_PER_QUERY=20
MIN_RELEVANCE_SCORE=0.3
MAX_CONCURRENT_SEARCHES=5

# Agent Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
LLM_TIMEOUT_SECONDS=60

# UI Settings
STREAM_UPDATE_INTERVAL_MS=500
MAX_HISTORY_ITEMS=10
