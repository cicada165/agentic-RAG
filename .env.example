# Deep Research Assistant - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Required: DeepSeek API Key for LLM
# Get your key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Optional: Search API Configuration
# For Tavily search (default): https://tavily.com/
# For Serper: https://serper.dev/
SEARCH_API_KEY=your-search-api-key-here
SEARCH_API_PROVIDER=tavily

# Optional: Embedding Model Configuration
# Default: sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_PATH=sentence-transformers/all-MiniLM-L6-v2

# Optional: Workflow Settings
MAX_RESEARCH_ITERATIONS=5
MAX_SOURCES_PER_QUERY=20
MIN_RELEVANCE_SCORE=0.3
MAX_CONCURRENT_SEARCHES=5

# Optional: LLM Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
LLM_TIMEOUT_SECONDS=60

# Optional: UI Settings
STREAM_UPDATE_INTERVAL_MS=500
MAX_HISTORY_ITEMS=10
