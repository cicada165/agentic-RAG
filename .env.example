# Deep Research Assistant - Environment Variables
# Copy this file to .env and fill in your API keys

# DeepSeek API Configuration (Required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Search API Configuration
# Options: tavily, serper, custom
SEARCH_API_PROVIDER=tavily

# Tavily API Key (Required if SEARCH_API_PROVIDER is tavily)
TAVILY_API_KEY=your_tavily_api_key_here

# Serper API Key (Required if SEARCH_API_PROVIDER is serper)
# SEARCH_API_KEY=your_serper_api_key_here

# General Search Key (Mapped to specific provider)
SEARCH_API_KEY=your_search_api_key_here

# Workflow Settings
MAX_RESEARCH_ITERATIONS=5
MAX_SOURCES_PER_QUERY=20
MIN_RELEVANCE_SCORE=0.3
MAX_CONCURRENT_SEARCHES=5

# LLM Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
LLM_TIMEOUT_SECONDS=60

# UI Settings
STREAM_UPDATE_INTERVAL_MS=500
MAX_HISTORY_ITEMS=10
